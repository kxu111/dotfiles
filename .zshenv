export XDG_CONFIG_HOME="$HOME/.config"
export PATH="$HOME/.cargo/bin:$PATH"
export UV_PYTHON="/run/current-system/sw/bin/python"
export UV_PYTHON_DOWNLOADS="never"
export PATH="/Users/kenny/.local/bin:$PATH"
export FZF_DEFAULT_OPTS="--layout=reverse --style=minimal --info=hidden --pointer='>' --no-bold --cycle"
export FZF_CTRL_T_OPTS="--highlight-line"
export FZF_DEFAULT_OPTS="$FZF_DEFAULT_OPTS
--color=fg:#c1c1c1,hl:#AAAAAA,gutter:#000000
--color=fg+:#000000,bg+:#9b8d7f,hl+:#000000
--color=info:#505050,prompt:#AAAAAA,pointer:#000000
--color=marker:#999999,spinner:#999999,header:#999999"
